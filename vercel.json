{
  "name": "calczp",
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "public": true,
  "env": [
    "POSTGRES_URL",
    "JWT_SECRET"
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 128,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}
